{
  "name": "lessmark-vscode",
  "displayName": "Lessmark",
  "description": "Syntax highlighting for Lessmark agent context files.",
  "version": "0.1.2",
  "publisher": "jasperdevs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasperdevs/lessmark.git",
    "directory": "editors/vscode"
  },
  "main": "./extension.js",
  "files": [
    "extension.js",
    "language-configuration.json",
    "syntaxes",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:lessmark",
    "onCommand:lessmark.check",
    "onCommand:lessmark.preview"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lessmark",
        "aliases": ["Lessmark", "lessmark"],
        "extensions": [".mu", ".lessmark"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lessmark",
        "scopeName": "source.lessmark",
        "path": "./syntaxes/lessmark.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "lessmark.check",
        "title": "Lessmark: Check Document"
      },
      {
        "command": "lessmark.preview",
        "title": "Lessmark: Preview Document"
      }
    ]
  }
}
