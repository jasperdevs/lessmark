{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lessmark.dev/schemas/ast-v0.schema.json",
  "title": "Lessmark AST v0",
  "type": "object",
  "required": ["type", "children"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "document" },
    "children": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "level", "text"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "heading" },
              "level": { "type": "integer", "minimum": 1, "maximum": 6 },
              "text": { "$ref": "#/$defs/headingText" }
            }
          },
          { "$ref": "#/$defs/noAttrBlock" },
          { "$ref": "#/$defs/decisionBlock" },
          { "$ref": "#/$defs/taskBlock" },
          { "$ref": "#/$defs/fileBlock" },
          { "$ref": "#/$defs/apiBlock" },
          { "$ref": "#/$defs/linkBlock" }
        ]
      }
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*</?[A-Za-z][A-Za-z0-9:-]*(?:\\s[^>]*)?>)[\\s\\S]*$"
    },
    "headingText": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "minLength": 1 }
      ]
    },
    "attributeValue": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "pattern": "^[^\\r\\n\\t]*$" }
      ]
    },
    "emptyAttrs": {
      "type": "object",
      "additionalProperties": false
    },
    "noAttrBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "enum": ["summary", "constraint", "example", "note", "warning"] },
        "attrs": { "$ref": "#/$defs/emptyAttrs" },
        "text": { "$ref": "#/$defs/safeText" }
      }
    },
    "decisionBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "const": "decision" },
        "attrs": {
          "type": "object",
          "required": ["id"],
          "additionalProperties": false,
          "properties": {
            "id": {
              "allOf": [
                { "$ref": "#/$defs/attributeValue" },
                { "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
              ]
            }
          }
        },
        "text": { "$ref": "#/$defs/safeText" }
      }
    },
    "taskBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "const": "task" },
        "attrs": {
          "type": "object",
          "required": ["status"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "allOf": [
                { "$ref": "#/$defs/attributeValue" },
                { "enum": ["todo", "doing", "done", "blocked"] }
              ]
            }
          }
        },
        "text": { "$ref": "#/$defs/safeText" }
      }
    },
    "fileBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "const": "file" },
        "attrs": {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": {
            "path": {
              "allOf": [
                { "$ref": "#/$defs/attributeValue" },
                {
                  "pattern": "^(?!/)(?!\\\\)(?![A-Za-z]:[\\\\/])(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
                }
              ]
            }
          }
        },
        "text": { "$ref": "#/$defs/safeText" }
      }
    },
    "apiBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "const": "api" },
        "attrs": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "allOf": [
                { "$ref": "#/$defs/attributeValue" },
                { "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$" }
              ]
            }
          }
        },
        "text": { "$ref": "#/$defs/safeText" }
      }
    },
    "linkBlock": {
      "type": "object",
      "required": ["type", "name", "attrs", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "block" },
        "name": { "const": "link" },
        "attrs": {
          "type": "object",
          "required": ["href"],
          "additionalProperties": false,
          "properties": {
            "href": {
              "allOf": [
                { "$ref": "#/$defs/attributeValue" },
                {
                  "pattern": "^(?!(?!(?:[Hh][Tt][Tt][Pp][Ss]?|[Mm][Aa][Ii][Ll][Tt][Oo]):)[A-Za-z][A-Za-z0-9+.-]*:).+"
                }
              ]
            }
          }
        },
        "text": { "$ref": "#/$defs/safeText" }
      }
    }
  }
}
