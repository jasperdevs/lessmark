{
  "name": "lessmark-workspace",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "lessmark-workspace",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/lessmark",
        "packages/cli"
      ]
    },
    "node_modules/@jasperdevs/lessmark-cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/lessmark": {
      "resolved": "packages/lessmark",
      "link": true
    },
    "packages/cli": {
      "name": "@jasperdevs/lessmark-cli",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "lessmark": "0.1.0"
      },
      "bin": {
        "lessmark": "bin/lessmark.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/lessmark": {
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    }
  }
}
